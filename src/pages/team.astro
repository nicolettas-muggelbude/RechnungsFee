import Layout from '../layouts/Layout.astro'

// Ideen zur Build-Zeit aus ROADMAP.md laden (kein Client-JS, kein CDN-Cache-Problem)
const ideenChips: string[] = await (async () => {
  const SKIP = /Barriere|Tastatur|Keyboard|Focus-|aria-|ARIA/i
  try {
    const res = await fetch(
      'https://raw.githubusercontent.com/nicolettas-muggelbude/RechnungsFee/main/docs/ROADMAP.md',
      { cache: 'no-store' }
    )
    if (!res.ok) return []
    const md = await res.text()
    let skip = false
    let inIdeen = false
    const ideen: string[] = []
    for (const line of md.split('\n')) {
      if (/^## /.test(line)) {
        skip = SKIP.test(line)
        inIdeen = /Ideen/i.test(line)
      }
      if (skip) continue
      const m = line.match(/^- \[ \] (.+)$/)
      if (m) {
        const text = m[1].trim()
        if (/^`|^<|aria-|role=|htmlFor|\[\s*\]/.test(text)) continue
        const label = text.split(/[:(]/)[0].trim()
        if (label.length >= 4 && label.length <= 45) ideen.push(label)
      }
      if (inIdeen) {
        const m2 = line.match(/^- \*\*(.+?)\*\*/)
        if (m2) {
          const label = m2[1].trim()
          if (label.length >= 4 && label.length <= 45) ideen.push(label)
        }
      }
    }
    return [...new Set(ideen)]
  } catch { return [] }
})()

