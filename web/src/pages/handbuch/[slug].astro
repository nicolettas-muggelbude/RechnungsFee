---
import { getCollection, render } from 'astro:content'
import HandbuchLayout from '../../layouts/HandbuchLayout.astro'

export async function getStaticPaths() {
  const pages = await getCollection('handbuch')
  return pages.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)

const title = headings.find(h => h.depth === 1)?.text ?? entry.id.replace(/-/g, ' ')
---

<HandbuchLayout title={title} currentSlug={entry.id}>
  <Content />
</HandbuchLayout>
