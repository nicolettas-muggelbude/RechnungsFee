{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RechnungsFee",
  "version": "0.1.0",
  "identifier": "de.rechnungsfee.app",
  "build": {
    "frontendDist": "../src/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd src/frontend && npm run dev",
    "beforeBuildCommand": "cd src/frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RechnungsFee",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/backend"]
  }
}
