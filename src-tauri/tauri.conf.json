{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RechnungsFee-Testing",
  "version": "0.1.0",
  "identifier": "de.rechnungsfee.testing",
  "build": {
    "frontendDist": "../src/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd src/frontend && npm run dev",
    "beforeBuildCommand": "cd src/frontend && npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nicolettas-muggelbude/RechnungsFee/releases/download/v0.1.36-testing.7/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwNTBDOTQ5RjJEQTlCMzcKUldRM205cnlTY2xROEI2WUpkbFhyajQ3dS9hQlkvWkc5ZHhPZnNkS3hNcEJZMWZFbTFzZUdVbVgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/backend"
    ]
  }
}
